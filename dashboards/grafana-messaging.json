{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }
  ],
  "title": "Messaging & Streaming — Lag and Backlog",
  "uid": "messaging-lag",
  "tags": ["observability", "messaging", "kafka", "template"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0 }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Consumer lag (messages behind)", "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [ { "expr": "sum by (consumergroup) (kafka_consumergroup_lag)", "legendFormat": "{{consumergroup}}", "refId": "A" } ]
    },
    {
      "id": 2, "title": "Publish vs consume rate", "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "description": "Publish sustainably above consume → backlog forming.",
      "fieldConfig": { "defaults": { "unit": "mps" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(messaging_published_total[5m]))", "legendFormat": "published", "refId": "A" },
        { "expr": "sum(rate(messaging_consumed_total[5m]))", "legendFormat": "consumed", "refId": "B" }
      ]
    },
    {
      "id": 3, "title": "Oldest unacked message age", "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [ { "expr": "max by (queue) (messaging_oldest_message_age_seconds)", "legendFormat": "{{queue}}", "refId": "A" } ]
    },
    {
      "id": 4, "title": "Dead-letter queue growth", "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [ { "expr": "sum by (queue) (increase(messaging_dlq_messages_total[15m]))", "legendFormat": "{{queue}}", "refId": "A" } ]
    },
    {
      "id": 5, "title": "Broker health — under-replicated / offline partitions", "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(kafka_under_replicated_partitions)", "legendFormat": "under-replicated", "refId": "A" },
        { "expr": "sum(kafka_offline_partitions_count)", "legendFormat": "offline", "refId": "B" }
      ]
    }
  ]
}
