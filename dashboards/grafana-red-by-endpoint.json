{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus-compatible data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "RED — Rate / Errors / Duration by Endpoint",
  "uid": "red-by-endpoint",
  "tags": ["observability", "RED", "template"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0 },
      {
        "name": "service",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Rate — requests/sec by route",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_requests_total{service=\"$service\"}[5m]))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Errors — 5xx ratio by route",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_requests_total{service=\"$service\",status_code=~\"5..\"}[5m])) / clamp_min(sum by (http_route) (rate(http_requests_total{service=\"$service\"}[5m])), 1)",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Duration — p99 by route",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, http_route) (rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Dependencies — downstream error ratio",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "description": "Per-dependency RED — isolates whether a fault is yours or a downstream's.",
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (peer_service) (rate(dependency_calls_total{service=\"$service\",outcome=\"error\"}[5m])) / clamp_min(sum by (peer_service) (rate(dependency_calls_total{service=\"$service\"}[5m])), 1)",
          "legendFormat": "{{peer_service}}",
          "refId": "A"
        }
      ]
    }
  ]
}
