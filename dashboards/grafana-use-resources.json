{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus-compatible data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "USE — Resource Utilization / Saturation / Errors",
  "uid": "use-resources",
  "tags": ["observability", "USE", "infrastructure", "template"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0 },
      {
        "name": "node",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(node_cpu_seconds_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU — utilization %",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.8 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{instance=~\"$node\",mode=\"idle\"}[5m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU — saturation (run-queue / load per core)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "description": "Load average normalized by core count. >1 sustained means work is waiting — this, not utilization, is the incident signal.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "node_load1{instance=~\"$node\"} / count by (instance) (node_cpu_seconds_total{instance=~\"$node\",mode=\"idle\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory — available %",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 0.1 }, { "color": "green", "value": 0.2 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{instance=~\"$node\"} / node_memory_MemTotal_bytes{instance=~\"$node\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Disk — used % (root)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.8 }, { "color": "red", "value": 0.9 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{instance=~\"$node\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=~\"$node\",mountpoint=\"/\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Disk I/O — saturation (await)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "rate(node_disk_io_time_weighted_seconds_total{instance=~\"$node\"}[5m])",
          "legendFormat": "{{instance}} {{device}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Network — errors + drops /sec",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "pps" }, "overrides": [] },
      "targets": [
        {
          "expr": "rate(node_network_receive_errs_total{instance=~\"$node\"}[5m]) + rate(node_network_receive_drop_total{instance=~\"$node\"}[5m])",
          "legendFormat": "{{instance}} {{device}} rx",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_errs_total{instance=~\"$node\"}[5m]) + rate(node_network_transmit_drop_total{instance=~\"$node\"}[5m])",
          "legendFormat": "{{instance}} {{device}} tx",
          "refId": "B"
        }
      ]
    }
  ]
}
